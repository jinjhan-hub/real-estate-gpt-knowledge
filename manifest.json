  },
  "recommended_query_examples": [
    "/api/knowledge-module?module=sales_generator&platform=fb&ratio=4:5&style=warm_home&stage=image_generation",
    "/api/knowledge-module?module=sales_generator&platform=ig&style=warm_home&stage=copy_generation",
    "/api/knowledge-module?module=sales_generator&platform=threads&style=first_buyer&stage=copy_generation"
  ],
  "change_log": [
    "v0.2.0：刪除 persona_shanshan 模組。",
    "v0.2.1：補強 loader order、模組 trigger 與全域確認流程對應。",
    "v0.2.2：補強 FB圖文 = 先圖卡後文案的任務分流規則。",
    "v0.2.3：修正 GitHub merged_upload_files 合併檔與周邊機能 API 欄位。",
    "v0.2.4：周邊機能 API 預設改為一次查詢五種 categories。",
    "v0.2.5：sales_generator 拆成 platform / ratio / style / workflow 四條線，新增 granular sales router 與圖片生成 failsafe。"
  ]
}
